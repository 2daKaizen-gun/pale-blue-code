# ============================================
# Pale Blue Code — .gitignore
# Node.js + Python + IDE + OS
# ============================================

# ---- Environment Variables ----
.env
.env.local
.env.*.local
!.env.example

# ---- Node.js / Frontend ----
node_modules/
dist/
build/
.next/
.nuxt/
.vite/
.cache/
.parcel-cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vite specific
.vite/

# Coverage
coverage/
*.lcov
.nyc_output/

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
.env.venv
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ---- Astronomy Data (큰 파일들) ----
# NASA / TESS / 케플러 raw 데이터는 레포에 올리지 않음
data/raw/
data/cache/
*.fits
*.fits.gz
*.h5
*.hdf5
lightcurves/
mast_cache/

# ---- IDE / Editor ----
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# JetBrains
*.iml
.idea_modules/

# Sublime
*.sublime-workspace
*.sublime-project

# ---- OS ----
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ---- Build / Deploy ----
.vercel/
.netlify/
.serverless/

# ---- Logs ----
logs/
*.log

# ---- Misc ----
.tmp/
tmp/
temp/
.local/